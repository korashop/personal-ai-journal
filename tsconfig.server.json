{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "./dist-server",
    "types": ["node"],
    "noEmit": false,
    "skipLibCheck": true
  },
  "include": ["server/**/*.ts", "src/types.ts"]
}
